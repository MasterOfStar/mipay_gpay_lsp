<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="MiPay GPay"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false">

        <!-- LSPosed 模块声明 -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposedmodname"
            android:value="MiPay GPay" />
        <meta-data
            android:name="xposedminversion"
            android:value="54" />

        <!-- LSPosed 作用域 -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />

        <!-- ContentProvider：在模块进程执行 su 命令（Wallet 进程通过 call() 调用） -->
        <provider
            android:name=".NfcProvider"
            android:authorities="com.mipay.gpay.lsp.provider"
            android:exported="true"
            android:process=":nfc_provider" />

    </application>

</manifest>
